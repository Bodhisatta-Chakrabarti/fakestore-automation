{
  "priority": 10,
  "request": {
    "method": "POST",
    "url": "/products",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.title"
      },
      {
        "matchesJsonPath": "$[?(@.price >= 0)]"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "create-product-success.json"
  }
}