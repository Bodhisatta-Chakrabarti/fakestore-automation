{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/products",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.price < 0)]"
      }
    ]
  },
  "response": {
    "status": 400,
    "jsonBody": {
      "error": "Invalid price"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  }
}