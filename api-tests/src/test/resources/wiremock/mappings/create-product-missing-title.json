{
  "request": {
    "method": "POST",
    "url": "/products",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(!@.title)]"
      }
    ]
  },
  "response": {
    "status": 400,
    "jsonBody": {
      "error": "Title is required"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  }
}